--
-- local.lua.example -- thin adapter for the AD-59 bootstrap module.
--
-- This is an EXAMPLE adapter for the current loader mechanism. It is deployed
-- into an instrumentation/test BE's /boot/lua/local.lua to exercise the
-- bootstrap module. It is intentionally thin: it requires the module and
-- delegates. It does NOT contain bootstrap logic itself.
--
-- It reports what discover() observed, then evaluates Selection Policy v1
-- via decide() and reports the selected role (AD-59 Parts 11 and 12,
-- Experiment 6). It performs no binding and no redirect: the role is
-- observed, not acted on. Bind and Transfer arrive with their contracts.
--

local ok, bootstrap = pcall(require, "pgsd_bootstrap")
if not ok then
	print("pgsd bootstrap: module load failed: " .. tostring(bootstrap))
	return
end

local obs = bootstrap.discover()

print("")
print("=== AD-59 Discover: LOM v" .. tostring(obs.lom_version) .. " ===")
print("=== selected_boot_environment   = " .. tostring(obs.selected_boot_environment))
-- available_boot_environments is a list; print a count and the entries.
local avail = obs.available_boot_environments
if type(avail) == "table" then
	print("=== available_boot_environments = " .. tostring(#avail) .. " entries")
	for i = 1, #avail do
		print("===   [" .. tostring(i) .. "] " .. tostring(avail[i]))
	end
else
	print("=== available_boot_environments = " .. tostring(avail))
end
print("=== operator_recovery_request   = " .. tostring(obs.operator_recovery_request))
print("=== promotion_state             = " .. tostring(obs.promotion_state))
print("=== boot_generation             = " .. tostring(obs.boot_generation))
local policy = bootstrap.SELECTION_POLICY_V1
local role = bootstrap.decide(obs, policy)

print("=== AD-59 Decide: Selection Policy v" .. tostring(policy.policy_version)
    .. " over LOM v" .. tostring(policy.lom_version) .. " ===")
print("=== selected role               = " .. tostring(role))
print("=== (Decide only: no binding, no redirect) ===")
print("")

-- Pause so the output stays on screen. Loader console output cannot be
-- scrolled back, and the loader continues to the menu immediately after
-- this file returns, so without a pause the whole block flashes past
-- faster than it can be read (bench 2026-07-02: Experiment 6 output was
-- unreadable until this pause was added). io.getchar() blocks until a
-- key is pressed; Experiment 3 established it works at loader stage.
-- This is an observation adapter, so pausing is correct: it performs no
-- redirect, and holding the boot for an operator keypress is the point.
print("=== press a key to continue boot ===")
io.getchar()
