--- /dev/null	2026-06-11 23:03:35.531269326 +0000
+++ b/semadraw/src/sdcs_decode.zig	2026-06-16 16:08:59.007333781 +0000
@@ -0,0 +1,502 @@
+//! Shared SDCS decoder (ADR semadraw 0019, Stage 1).
+//!
+//! One framing walk for the SemaDraw Command Stream, replacing the per-backend
+//! hand-rolled header/chunk/command loops that each re-derived the format from
+//! hardcoded opcode magic. This module is the single reader: it walks the 64
+//! byte header, the 32 byte chunk headers, and the 8 byte command records (each
+//! padded to an 8 byte boundary), and yields a typed `Command` for each record.
+//!
+//! It dispatches on the canonical `sdcs.Op` constants, so an opcode added or
+//! renumbered in sdcs.zig is a compile concern here, and the `Command` union is
+//! exhaustive, so every consumer that switches on it must handle every opcode
+//! (including `.unknown`) or fail to compile. That is the property ADR 0019
+//! exists to restore: no silent drop of an unhandled opcode.
+//!
+//! Stage 1 scope: the framing walk is complete, and every fixed-layout opcode is
+//! fully decoded into named fields (this covers the entire set the live path
+//! emits). The variable-length opcodes (paths, gradients, patterns, glyph runs,
+//! blits, clip paths) carry their raw payload slice for now; structural decode
+//! of those sub-formats is the bounded follow-up in this stage. SET_CLIP_RECTS
+//! is decoded to a typed view since its layout is trivial. No backend consumes
+//! this yet; that is Stage 2.
+
+const std = @import("std");
+const sdcs = @import("sdcs");
+
+pub const DecodeError = error{
+    /// Buffer is smaller than a single SDCS header.
+    TooShort,
+    /// Magic prefix is not "SDCS".
+    BadMagic,
+    /// A command's declared payload runs past the end of its chunk, or a known
+    /// opcode carries fewer payload bytes than its fixed layout requires.
+    Truncated,
+};
+
+// ---------------------------------------------------------------------------
+// Decoded payload shapes (fixed-layout opcodes). Field order matches encoder.zig.
+// ---------------------------------------------------------------------------
+
+pub const FillRect = struct { x: f32, y: f32, w: f32, h: f32, r: f32, g: f32, b: f32, a: f32 };
+pub const StrokeRect = struct { x: f32, y: f32, w: f32, h: f32, stroke_width: f32, r: f32, g: f32, b: f32, a: f32 };
+pub const StrokeLine = struct { x1: f32, y1: f32, x2: f32, y2: f32, stroke_width: f32, r: f32, g: f32, b: f32, a: f32 };
+pub const Transform2D = struct { a: f32, b: f32, c: f32, d: f32, e: f32, f: f32 };
+pub const QuadBezier = struct { x0: f32, y0: f32, cx: f32, cy: f32, x1: f32, y1: f32, stroke_width: f32, r: f32, g: f32, b: f32, a: f32 };
+pub const CubicBezier = struct { x0: f32, y0: f32, cx1: f32, cy1: f32, cx2: f32, cy2: f32, x1: f32, y1: f32, stroke_width: f32, r: f32, g: f32, b: f32, a: f32 };
+
+/// A typed view over a SET_CLIP_RECTS payload: u32 count followed by `count`
+/// rects of four f32 (x, y, w, h). Borrows the payload; valid only while the
+/// decoded buffer lives.
+pub const ClipRects = struct {
+    payload: []const u8,
+
+    pub fn count(self: ClipRects) u32 {
+        if (self.payload.len < 4) return 0;
+        return rdU32(self.payload[0..]);
+    }
+
+    /// Rect at index `i`, or null if out of range / truncated.
+    pub fn at(self: ClipRects, i: u32) ?sdcs_Rect {
+        if (i >= self.count()) return null;
+        const base = 4 + @as(usize, i) * 16;
+        if (base + 16 > self.payload.len) return null;
+        return .{
+            .x = rdF32(self.payload[base + 0 ..]),
+            .y = rdF32(self.payload[base + 4 ..]),
+            .w = rdF32(self.payload[base + 8 ..]),
+            .h = rdF32(self.payload[base + 12 ..]),
+        };
+    }
+};
+
+pub const sdcs_Rect = struct { x: f32, y: f32, w: f32, h: f32 };
+
+/// An opcode the decoder does not have a typed variant for. Surfaced rather than
+/// dropped so consumers must decide explicitly (ADR 0019 decision 4).
+pub const Unknown = struct { opcode: u16, payload: []const u8 };
+
+// ---------------------------------------------------------------------------
+// Command union. One variant per canonical opcode; the tag is generated by Zig
+// and switches over it are exhaustiveness-checked.
+// ---------------------------------------------------------------------------
+
+pub const Command = union(enum) {
+    reset,
+    set_clip_rects: ClipRects,
+    clear_clip,
+    set_blend: u32,
+    set_transform_2d: Transform2D,
+    reset_transform,
+    set_antialias: bool,
+    set_source_none,
+    set_source_linear_gradient: []const u8,
+    set_source_radial_gradient: []const u8,
+    set_source_pattern: []const u8,
+    set_clip_path: []const u8,
+    fill_rect: FillRect,
+    stroke_rect: StrokeRect,
+    stroke_line: StrokeLine,
+    set_stroke_join: u32,
+    set_stroke_cap: u32,
+    set_miter_limit: f32,
+    stroke_quad_bezier: QuadBezier,
+    stroke_cubic_bezier: CubicBezier,
+    stroke_path: []const u8,
+    fill_path: []const u8,
+    blit_image: []const u8,
+    draw_glyph_run: []const u8,
+    end,
+    unknown: Unknown,
+};
+
+// ---------------------------------------------------------------------------
+// Little-endian field readers. Callers guarantee the slice is long enough.
+// ---------------------------------------------------------------------------
+
+inline fn rdU16(b: []const u8) u16 {
+    return std.mem.readInt(u16, b[0..2], .little);
+}
+inline fn rdU32(b: []const u8) u32 {
+    return std.mem.readInt(u32, b[0..4], .little);
+}
+inline fn rdU64(b: []const u8) u64 {
+    return std.mem.readInt(u64, b[0..8], .little);
+}
+inline fn rdF32(b: []const u8) f32 {
+    return @bitCast(rdU32(b));
+}
+
+// ChunkHeader field offsets (extern struct in sdcs.zig).
+const CH_TYPE = 0; // u32
+const CH_PAYLOAD_BYTES = 24; // u64
+
+// ---------------------------------------------------------------------------
+// Decoder: an iterator over the command stream, transparent across chunks.
+// ---------------------------------------------------------------------------
+
+pub const Decoder = struct {
+    data: []const u8,
+    /// Absolute offset of the next chunk header to read.
+    chunk_off: usize,
+    /// Absolute offset of the next command record within the current chunk.
+    cmd_off: usize,
+    /// Absolute end of the current chunk's command region.
+    cmd_end: usize,
+    /// True when the current chunk is exhausted (region end reached or END seen).
+    chunk_done: bool,
+
+    pub fn init(data: []const u8) DecodeError!Decoder {
+        if (data.len < @sizeOf(sdcs.Header)) return error.TooShort;
+        if (!std.mem.eql(u8, data[0..4], sdcs.MagicPrefix)) return error.BadMagic;
+        return .{
+            .data = data,
+            .chunk_off = @sizeOf(sdcs.Header),
+            .cmd_off = 0,
+            .cmd_end = 0,
+            .chunk_done = true,
+        };
+    }
+
+    /// Next command, or null at clean end of stream.
+    pub fn next(self: *Decoder) DecodeError!?Command {
+        while (true) {
+            if (self.chunk_done or self.cmd_off + @sizeOf(sdcs.CmdHdr) > self.cmd_end) {
+                if (!self.advanceChunk()) return null;
+                continue;
+            }
+            return try self.decodeAt();
+        }
+    }
+
+    /// Move to the next CMDS chunk; returns false when no more chunks remain.
+    /// Non-CMDS chunks (RSRC/DATA/META) are skipped, which the legacy per-backend
+    /// loops failed to do (they treated every chunk as commands).
+    fn advanceChunk(self: *Decoder) bool {
+        while (self.chunk_off + @sizeOf(sdcs.ChunkHeader) <= self.data.len) {
+            const co = self.chunk_off;
+            const ctype = rdU32(self.data[co + CH_TYPE ..]);
+            const payload_bytes: usize = @intCast(rdU64(self.data[co + CH_PAYLOAD_BYTES ..]));
+            const region_start = co + @sizeOf(sdcs.ChunkHeader);
+
+            var region_end = region_start + payload_bytes;
+            if (region_end > self.data.len) region_end = self.data.len; // tolerate truncation
+
+            // Next chunk starts after this chunk's payload, padded to 8.
+            self.chunk_off = std.mem.alignForward(usize, region_end, 8);
+
+            if (ctype == sdcs.ChunkType.CMDS) {
+                self.cmd_off = region_start;
+                self.cmd_end = region_end;
+                self.chunk_done = false;
+                return true;
+            }
+            // else: skip this chunk and keep scanning.
+        }
+        return false;
+    }
+
+    /// Decode the command record at cmd_off and advance past it.
+    fn decodeAt(self: *Decoder) DecodeError!Command {
+        const co = self.cmd_off;
+        const opcode = rdU16(self.data[co..]);
+        const plen: usize = @intCast(rdU32(self.data[co + 4 ..]));
+        const pstart = co + @sizeOf(sdcs.CmdHdr);
+        if (pstart + plen > self.cmd_end) return error.Truncated;
+        const payload = self.data[pstart .. pstart + plen];
+
+        const record = @sizeOf(sdcs.CmdHdr) + plen;
+        self.cmd_off = co + std.mem.alignForward(usize, record, 8);
+
+        if (opcode == sdcs.Op.END) self.chunk_done = true;
+        return try decodeOne(opcode, payload);
+    }
+};
+
+/// Map an opcode and its raw payload to a typed Command. Fixed-layout opcodes are
+/// length-checked and fully decoded; variable opcodes carry their payload slice.
+fn decodeOne(opcode: u16, payload: []const u8) DecodeError!Command {
+    return switch (opcode) {
+        sdcs.Op.RESET => .reset,
+        sdcs.Op.CLEAR_CLIP => .clear_clip,
+        sdcs.Op.RESET_TRANSFORM => .reset_transform,
+        sdcs.Op.SET_SOURCE_NONE => .set_source_none,
+        sdcs.Op.END => .end,
+
+        sdcs.Op.SET_BLEND => blk: {
+            try need(payload, 4);
+            break :blk .{ .set_blend = rdU32(payload) };
+        },
+        sdcs.Op.SET_ANTIALIAS => blk: {
+            try need(payload, 4);
+            break :blk .{ .set_antialias = rdU32(payload) != 0 };
+        },
+        sdcs.Op.SET_STROKE_JOIN => blk: {
+            try need(payload, 4);
+            break :blk .{ .set_stroke_join = rdU32(payload) };
+        },
+        sdcs.Op.SET_STROKE_CAP => blk: {
+            try need(payload, 4);
+            break :blk .{ .set_stroke_cap = rdU32(payload) };
+        },
+        sdcs.Op.SET_MITER_LIMIT => blk: {
+            try need(payload, 4);
+            break :blk .{ .set_miter_limit = rdF32(payload) };
+        },
+
+        sdcs.Op.SET_TRANSFORM_2D => blk: {
+            try need(payload, 24);
+            break :blk .{ .set_transform_2d = .{
+                .a = rdF32(payload[0..]),  .b = rdF32(payload[4..]),
+                .c = rdF32(payload[8..]),  .d = rdF32(payload[12..]),
+                .e = rdF32(payload[16..]), .f = rdF32(payload[20..]),
+            } };
+        },
+
+        sdcs.Op.FILL_RECT => blk: {
+            try need(payload, 32);
+            break :blk .{ .fill_rect = .{
+                .x = rdF32(payload[0..]),  .y = rdF32(payload[4..]),
+                .w = rdF32(payload[8..]),  .h = rdF32(payload[12..]),
+                .r = rdF32(payload[16..]), .g = rdF32(payload[20..]),
+                .b = rdF32(payload[24..]), .a = rdF32(payload[28..]),
+            } };
+        },
+        sdcs.Op.STROKE_RECT => blk: {
+            try need(payload, 36);
+            break :blk .{ .stroke_rect = .{
+                .x = rdF32(payload[0..]),  .y = rdF32(payload[4..]),
+                .w = rdF32(payload[8..]),  .h = rdF32(payload[12..]),
+                .stroke_width = rdF32(payload[16..]),
+                .r = rdF32(payload[20..]), .g = rdF32(payload[24..]),
+                .b = rdF32(payload[28..]), .a = rdF32(payload[32..]),
+            } };
+        },
+        sdcs.Op.STROKE_LINE => blk: {
+            try need(payload, 36);
+            break :blk .{ .stroke_line = .{
+                .x1 = rdF32(payload[0..]),  .y1 = rdF32(payload[4..]),
+                .x2 = rdF32(payload[8..]),  .y2 = rdF32(payload[12..]),
+                .stroke_width = rdF32(payload[16..]),
+                .r = rdF32(payload[20..]), .g = rdF32(payload[24..]),
+                .b = rdF32(payload[28..]), .a = rdF32(payload[32..]),
+            } };
+        },
+        sdcs.Op.STROKE_QUAD_BEZIER => blk: {
+            try need(payload, 44);
+            break :blk .{ .stroke_quad_bezier = .{
+                .x0 = rdF32(payload[0..]), .y0 = rdF32(payload[4..]),
+                .cx = rdF32(payload[8..]), .cy = rdF32(payload[12..]),
+                .x1 = rdF32(payload[16..]), .y1 = rdF32(payload[20..]),
+                .stroke_width = rdF32(payload[24..]),
+                .r = rdF32(payload[28..]), .g = rdF32(payload[32..]),
+                .b = rdF32(payload[36..]), .a = rdF32(payload[40..]),
+            } };
+        },
+        sdcs.Op.STROKE_CUBIC_BEZIER => blk: {
+            // Encoder writes 52 bytes (13 f32). Note: sdcs.zig's generated
+            // comment says 60b; tracked as a constants/encoder drift under 0019.
+            try need(payload, 52);
+            break :blk .{ .stroke_cubic_bezier = .{
+                .x0 = rdF32(payload[0..]),  .y0 = rdF32(payload[4..]),
+                .cx1 = rdF32(payload[8..]), .cy1 = rdF32(payload[12..]),
+                .cx2 = rdF32(payload[16..]), .cy2 = rdF32(payload[20..]),
+                .x1 = rdF32(payload[24..]), .y1 = rdF32(payload[28..]),
+                .stroke_width = rdF32(payload[32..]),
+                .r = rdF32(payload[36..]), .g = rdF32(payload[40..]),
+                .b = rdF32(payload[44..]), .a = rdF32(payload[48..]),
+            } };
+        },
+
+        sdcs.Op.SET_CLIP_RECTS => .{ .set_clip_rects = .{ .payload = payload } },
+
+        // Variable-length opcodes: raw payload for Stage 1.
+        sdcs.Op.SET_SOURCE_LINEAR_GRADIENT => .{ .set_source_linear_gradient = payload },
+        sdcs.Op.SET_SOURCE_RADIAL_GRADIENT => .{ .set_source_radial_gradient = payload },
+        sdcs.Op.SET_SOURCE_PATTERN => .{ .set_source_pattern = payload },
+        sdcs.Op.SET_CLIP_PATH => .{ .set_clip_path = payload },
+        sdcs.Op.STROKE_PATH => .{ .stroke_path = payload },
+        sdcs.Op.FILL_PATH => .{ .fill_path = payload },
+        sdcs.Op.BLIT_IMAGE => .{ .blit_image = payload },
+        sdcs.Op.DRAW_GLYPH_RUN => .{ .draw_glyph_run = payload },
+
+        else => .{ .unknown = .{ .opcode = opcode, .payload = payload } },
+    };
+}
+
+inline fn need(payload: []const u8, n: usize) DecodeError!void {
+    if (payload.len < n) return error.Truncated;
+}
+
+// ===========================================================================
+// Tests
+// ===========================================================================
+
+const testing = std.testing;
+
+/// Build an SDCS buffer (header + single CMDS chunk) from a sequence of
+/// already-encoded command records, mirroring encoder.finishBytesWithHeader so
+/// the decoder is tested against the real on-wire framing.
+const TestBuilder = struct {
+    cmds: std.ArrayList(u8) = .empty,
+
+    fn append(self: *TestBuilder, a: std.mem.Allocator, opcode: u16, payload: []const u8) !void {
+        var hdr: [8]u8 = undefined;
+        std.mem.writeInt(u16, hdr[0..2], opcode, .little);
+        std.mem.writeInt(u16, hdr[2..4], 0, .little);
+        std.mem.writeInt(u32, hdr[4..8], @intCast(payload.len), .little);
+        try self.cmds.appendSlice(a, hdr[0..]);
+        if (payload.len != 0) try self.cmds.appendSlice(a, payload);
+        const pad = sdcs.pad8Len(8 + payload.len);
+        var i: usize = 0;
+        while (i < pad) : (i += 1) try self.cmds.append(a, 0);
+    }
+
+    fn finish(self: *TestBuilder, a: std.mem.Allocator) ![]u8 {
+        const payload_len = self.cmds.items.len;
+        const total = @sizeOf(sdcs.Header) + @sizeOf(sdcs.ChunkHeader) + payload_len;
+        const buf = try a.alloc(u8, total);
+        @memset(buf, 0);
+        var h: sdcs.Header = .{
+            .magic = undefined,
+            .version_major = sdcs.version_major,
+            .version_minor = sdcs.version_minor,
+            .header_bytes = @sizeOf(sdcs.Header),
+            .flags = 0,
+            .chunk_count = 1,
+            .stream_bytes = total,
+            .chunk_dir_offset = @sizeOf(sdcs.Header),
+            .reserved0 = 0,
+            .reserved1 = 0,
+            .reserved2 = 0,
+        };
+        @memcpy(h.magic[0..], sdcs.Magic);
+        @memcpy(buf[0..@sizeOf(sdcs.Header)], std.mem.asBytes(&h));
+        var ch: sdcs.ChunkHeader = .{
+            .type = sdcs.ChunkType.CMDS,
+            .flags = 0,
+            .offset = @sizeOf(sdcs.Header),
+            .bytes = @sizeOf(sdcs.ChunkHeader) + payload_len,
+            .payload_bytes = payload_len,
+        };
+        @memcpy(buf[@sizeOf(sdcs.Header)..][0..@sizeOf(sdcs.ChunkHeader)], std.mem.asBytes(&ch));
+        @memcpy(buf[@sizeOf(sdcs.Header) + @sizeOf(sdcs.ChunkHeader) ..][0..payload_len], self.cmds.items);
+        return buf;
+    }
+
+    fn deinit(self: *TestBuilder, a: std.mem.Allocator) void {
+        self.cmds.deinit(a);
+    }
+};
+
+fn f32le(v: f32) [4]u8 {
+    var b: [4]u8 = undefined;
+    std.mem.writeInt(u32, b[0..4], @bitCast(v), .little);
+    return b;
+}
+fn u32le(v: u32) [4]u8 {
+    var b: [4]u8 = undefined;
+    std.mem.writeInt(u32, b[0..4], v, .little);
+    return b;
+}
+
+test "header validation" {
+    try testing.expectError(error.TooShort, Decoder.init("short"));
+    var bad: [64]u8 = .{0} ** 64;
+    try testing.expectError(error.BadMagic, Decoder.init(&bad));
+}
+
+test "fixed opcodes decode with correct fields, END terminates" {
+    const a = testing.allocator;
+    var tb: TestBuilder = .{};
+    defer tb.deinit(a);
+
+    try tb.append(a, sdcs.Op.RESET, &.{});
+    {
+        var p: [32]u8 = undefined;
+        inline for (.{ 1.0, 2.0, 3.0, 4.0, 0.5, 0.6, 0.7, 0.8 }, 0..) |v, i| {
+            @memcpy(p[i * 4 ..][0..4], &f32le(v));
+        }
+        try tb.append(a, sdcs.Op.FILL_RECT, &p);
+    }
+    try tb.append(a, sdcs.Op.SET_BLEND, &u32le(3));
+    {
+        var p: [36]u8 = undefined;
+        inline for (.{ 10.0, 11.0, 12.0, 13.0, 2.5, 0.1, 0.2, 0.3, 0.4 }, 0..) |v, i| {
+            @memcpy(p[i * 4 ..][0..4], &f32le(v));
+        }
+        try tb.append(a, sdcs.Op.STROKE_LINE, &p);
+    }
+    try tb.append(a, sdcs.Op.END, &.{});
+
+    const buf = try tb.finish(a);
+    defer a.free(buf);
+
+    var d = try Decoder.init(buf);
+
+    try testing.expect((try d.next()).? == .reset);
+
+    const fr = (try d.next()).?.fill_rect;
+    try testing.expectEqual(@as(f32, 1.0), fr.x);
+    try testing.expectEqual(@as(f32, 4.0), fr.h);
+    try testing.expectEqual(@as(f32, 0.8), fr.a);
+
+    try testing.expectEqual(@as(u32, 3), (try d.next()).?.set_blend);
+
+    const sl = (try d.next()).?.stroke_line;
+    try testing.expectEqual(@as(f32, 10.0), sl.x1);
+    try testing.expectEqual(@as(f32, 2.5), sl.stroke_width);
+    try testing.expectEqual(@as(f32, 0.4), sl.a);
+
+    try testing.expect((try d.next()).? == .end);
+    try testing.expect((try d.next()) == null);
+}
+
+test "clip rects typed view" {
+    const a = testing.allocator;
+    var tb: TestBuilder = .{};
+    defer tb.deinit(a);
+
+    var p: [4 + 32]u8 = undefined;
+    @memcpy(p[0..4], &u32le(2));
+    const rects = [_]f32{ 1, 2, 3, 4, 5, 6, 7, 8 };
+    inline for (rects, 0..) |v, i| @memcpy(p[4 + i * 4 ..][0..4], &f32le(v));
+    try tb.append(a, sdcs.Op.SET_CLIP_RECTS, &p);
+    try tb.append(a, sdcs.Op.END, &.{});
+
+    const buf = try tb.finish(a);
+    defer a.free(buf);
+
+    var d = try Decoder.init(buf);
+    const cr = (try d.next()).?.set_clip_rects;
+    try testing.expectEqual(@as(u32, 2), cr.count());
+    try testing.expectEqual(@as(f32, 1), cr.at(0).?.x);
+    try testing.expectEqual(@as(f32, 8), cr.at(1).?.h);
+    try testing.expect(cr.at(2) == null);
+}
+
+test "unknown opcode is surfaced, not dropped" {
+    const a = testing.allocator;
+    var tb: TestBuilder = .{};
+    defer tb.deinit(a);
+    try tb.append(a, 0x7777, &.{ 1, 2, 3, 4 });
+    try tb.append(a, sdcs.Op.END, &.{});
+    const buf = try tb.finish(a);
+    defer a.free(buf);
+
+    var d = try Decoder.init(buf);
+    const u = (try d.next()).?.unknown;
+    try testing.expectEqual(@as(u16, 0x7777), u.opcode);
+    try testing.expectEqual(@as(usize, 4), u.payload.len);
+    try testing.expect((try d.next()).? == .end);
+}
+
+test "truncated fixed payload errors" {
+    const a = testing.allocator;
+    var tb: TestBuilder = .{};
+    defer tb.deinit(a);
+    try tb.append(a, sdcs.Op.FILL_RECT, &.{ 0, 0, 0, 0 }); // 4 bytes, needs 32
+    const buf = try tb.finish(a);
+    defer a.free(buf);
+    var d = try Decoder.init(buf);
+    try testing.expectError(error.Truncated, d.next());
+}
