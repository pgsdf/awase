# AD-39: in-tree console drivers and their framebuffer backends
# are removed. drawfs has exclusive ownership of the EFI
# framebuffer once drawfs.ko loads.
#
# Removed:
#   sc, vga, splash, SC_PIXEL_MODE
#       syscons legacy console driver and its VGA backend.
#   vt, vt_vga, vt_efifb, vt_vbefb
#       vt(4) default console driver and its framebuffer
#       backends. vt(4) and drawfs were both writing to the
#       same physical address 0xc0180000 in the 2026-05-13
#       bench session, causing cursor sprites to be
#       overwritten by vt(4) repaints.
#
# Consequence: no kernel-level console on the framebuffer.
# Boot messages do not appear on the display; recovery from
# kernel panic or boot failure requires SSH from another
# machine on the network, serial console (uncommon on iMac
# hardware), or boot from rescue media (FreeBSD installer
# USB). Verify at least one recovery path BEFORE rebooting
# into a PGSD kernel built from this config; pgsd-kernel-build.sh's
# pre-flight phase (phase_check) enforces this by refusing
# to build the kernel if sshd is not configured and running.
# The check was previously a standalone pgsd-kernel-preflight.sh
# script that no longer exists; functionality was consolidated
# into the build script during AD-39's tooling work. See
# BACKLOG.md AD-39 "Recovery-path check" for the full history.

# drawfs: the framebuffer owner, compiled in.
#
# drawfs ADR 0001 amendment (2026-07-13). drawfs replaces vt and
# vt_efifb, removed above. Those are not modules and cannot be: there
# is no sys/modules/vt. The framebuffer owner is a bootstrap
# dependency, so it must exist before anything can claim the
# framebuffer, and a module loaded later is a module that races. That
# race is exactly what AD-39 was written to prevent. Compiling drawfs
# in eliminates it by construction rather than by load ordering.
#
# It also removes drawfs's dependency on the loader, which is what
# broke on metal (campaign finding F14): pgsd-loader builds a module
# chain containing exactly one entry, the kernel. It does not read
# /boot/loader.conf and cannot preload a .ko, so drawfs was never
# loaded on an armed boot, nothing owned the framebuffer, and nothing
# drew. Compiled in, it is simply there.
#
# inputfs and audiofs stay MODULES, deliberately. The same principle
# gives them a different answer, which is the sign it is a principle
# and not a rule of thumb: they replace modules (sys/modules/hid/hkbd,
# sys/modules/sound/driver/hda), neither is a bootstrap dependency, and
# both MUST load after root mounts. inputfs panics if loaded before
# /var/run exists; audiofs's rc.d service carries REQUIRE: FILESYSTEMS.
# Only the framebuffer owner has to exist before anything else can
# touch what it owns.
#
# The source list lives beside this config rather than in
# sys/conf/files, so the pinned FreeBSD tree is not modified (AD-57).
# config(8) supports this (usr.sbin/config/config.y: FILES ID SEMICOLON)
# and sys/arm/conf/GENERIC uses it the same way.
files		"files.drawfs"
device		drawfs			# PGSD framebuffer substrate (AD-39, ADR 0001)

# bootcrumb: early-boot progress instrumentation.
#
# This kernel has NO CONSOLE. AD-39 removed vt, vt_efifb, sc and vga so
# drawfs could own the framebuffer, and the only console left is a UART at
# a legacy I/O port that this hardware does not have. So a kernel that
# panics, hangs, or blocks at an invisible mountroot> prompt looks exactly
# like one that never started: a blank screen.
#
# The L3a campaign spent seven armed boots and two reinstalls
# distinguishing those cases by inference. bootcrumb writes EFI variables
# from SYSINITs so the kernel can say where it got to, and rc.d writes one
# more once root is actually mounted. PreMountRoot present with no
# RootMounted is the signature of a root that could not be mounted, which
# was invisible for the whole campaign.
#
# It cannot observe anything before SI_SUB_DRIVERS: efirt attaches there,
# and without it there are no runtime services to call. That gap is
# covered from the other side by the loader's own NVRAM marker.
files		"files.bootcrumb"
device		bootcrumb		# early-boot progress via EFI variables

